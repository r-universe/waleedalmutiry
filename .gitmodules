[submodule ".registry"]
	path = .registry
	url = https://github.com/r-universe-org/cran-to-git
	shallow = true
	branch = HEAD
[submodule "EpiILMCT"]
	path = EpiILMCT
	url = https://github.com/waleedalmutiry/epiilmct
	shallow = true
	registered = true
[submodule "EpiILM"]
	path = EpiILM
	url = https://github.com/waleedalmutiry/epiilm
	shallow = true
	registered = true
